# Copy to .env for local overrides (optional)
POSTGRES_DB=ai_receptionist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host ports
FRONTEND_PORT=8080
BACKEND_PORT=8000
DB_PORT=5432

# Backend configuration
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ai_receptionist
APP_ENV=development
CORS_ALLOW_ORIGINS=*
LOG_LEVEL=INFO
LOG_JSON=false
RATE_LIMIT=60/minute

# Admin API key — required for /api/booking-requests and /api/email/test
# In development, endpoints are open if unset; in production, ADMIN_API_KEY is mandatory (32+ chars).
ADMIN_API_KEY=
ADMIN_API_KEY_PREVIOUS=

# Zero-trust session HMAC (required in production)
SESSION_SECRET=
JWT_SECRET=

# MFA for admin (generate: python -c "import pyotp; print(pyotp.random_base32())")
ADMIN_TOTP_SECRET=

# Fernet key for PII encryption at rest (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=

# Observability & alerting
SENTRY_DSN=
ALERT_WEBHOOK_URL=

# Hosted LLM — put your real key in .env only (never commit .env)
LLM_ENABLED=false
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
API_KEY=
# Legacy aliases also supported: LLM_API_KEY, GEMINI_API_KEY, OPENAI_API_KEY
LLM_TIMEOUT_SECONDS=15
LLM_MAX_HISTORY_MESSAGES=20
LLM_CHAT_TEMPERATURE=0.6
LLM_CHAT_MAX_TOKENS=450

# Booking confirmation emails — put real credentials in .env only (never commit .env)
# Emails send automatically once a provider is configured (Mailpit, Resend, or Gmail SMTP).
EMAIL_ENABLED=true
EMAIL_PROVIDER=auto
BOOKING_NOTIFY_EMAIL=
HOTEL_NAME=SMART Hotel

# Option A: Mailpit (Docker default — view inbox at http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@smart.local
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# Option B: Resend — real inbox delivery (free at https://resend.com)
RESEND_API_KEY=
RESEND_FROM=SMART Hotel <onboarding@resend.dev>

# Option C: Gmail SMTP — requires App Password (https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# EMAIL_FROM=you@gmail.com
