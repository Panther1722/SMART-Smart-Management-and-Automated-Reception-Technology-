# Production environment template — never commit real secrets
APP_ENV=production
LOG_LEVEL=INFO
LOG_JSON=true
CORS_ALLOW_ORIGINS=https://your-frontend.example.com
RATE_LIMIT=60/minute

ADMIN_API_KEY=replace-with-48-char-random-key-from-rotate_admin_key.py
ADMIN_API_KEY_PREVIOUS=
SESSION_SECRET=replace-with-random-64-char-secret
JWT_SECRET=replace-with-random-jwt-secret
ADMIN_TOTP_SECRET=replace-with-pyotp-base32-secret
FIELD_ENCRYPTION_KEY=replace-with-fernet-key

DATABASE_URL=postgresql+psycopg2://user:password@db-host:5432/ai_receptionist
EMAIL_ENABLED=true
LLM_ENABLED=false
SENTRY_DSN=https://your-sentry-dsn
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx
