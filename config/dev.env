# Development environment — copy to .env or use with docker compose
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false
CORS_ALLOW_ORIGINS=*
RATE_LIMIT=120/minute

ADMIN_API_KEY=dev-admin-key-change-me-in-production
SESSION_SECRET=dev-session-secret-change-in-production
JWT_SECRET=dev-jwt-secret
ADMIN_TOTP_SECRET=
FIELD_ENCRYPTION_KEY=

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ai_receptionist
EMAIL_ENABLED=true
LLM_ENABLED=false
SENTRY_DSN=
ALERT_WEBHOOK_URL=
